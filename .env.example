# Bắt buộc: tạo app tại https://dashboard.privy.io (bật login Email + Google,
# Embedded wallets: create on login)
NEXT_PUBLIC_PRIVY_APP_ID=

# "base" cho mainnet; bỏ trống / giá trị khác = Base Sepolia (dev)
NEXT_PUBLIC_CHAIN=

# Địa chỉ AccountFactory khi contracts deploy lên Base (Vũ cung cấp).
# Bỏ trống = Phase 0: địa chỉ heo đất là chính ví embedded.
NEXT_PUBLIC_FACTORY_ADDRESS=

# Cổng nạp fiat (thẻ/PayPal). Bỏ trống = DEV MODE (mô phỏng checkout + tiền sandbox).
# Đặt URL backend on-ramp để bật chế độ thật (xem API.md /onramp/session).
NEXT_PUBLIC_ONRAMP_URL=
