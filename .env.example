# Bắt buộc: tạo app tại https://dashboard.privy.io (bật login Email + Google,
# Embedded wallets: create on login)
NEXT_PUBLIC_PRIVY_APP_ID=

# "base" cho mainnet; bỏ trống / giá trị khác = Ethereum Sepolia (dev)
NEXT_PUBLIC_CHAIN=

# Backend engine (web/API.md). Đặt = FE dùng backend (portfolio/operations/on-ramp) — chạy
# thật e2e. Bỏ trống = client sim (standalone, không cần backend).
# Dev backend: cd backend && npx wrangler dev --port 8789  →  http://localhost:8789
NEXT_PUBLIC_API_URL=

# Ops indexer (cryptopiggy-ops). Đặt = Portfolio đọc lãi thật (value − principal) + activity từ
# endpoint public /account/:addr. Bỏ trống = activity rỗng, lãi 0 (positions vẫn đọc từ chain).
NEXT_PUBLIC_OPS_URL=

# Địa chỉ AccountFactory khi contracts deploy (Vũ cung cấp).
# Bỏ trống = địa chỉ heo đất là chính ví embedded.
NEXT_PUBLIC_FACTORY_ADDRESS=

# Gasless (EIP-7702 + Pimlico). Có key = user zero-gas: ví embedded được 7702-delegate,
# phí gas trả qua paymaster. Bỏ trống = ví tự trả gas bằng ETH (phải nạp tay).
# Tạo tại https://dashboard.pimlico.io → API key + Sponsorship Policy (chọn network Sepolia).
NEXT_PUBLIC_PIMLICO_API_KEY=
NEXT_PUBLIC_SPONSORSHIP_POLICY_ID=
# Optional: RPC Sepolia riêng cho reads (Alchemy/Infura). Trống = transport mặc định.
NEXT_PUBLIC_SEPOLIA_RPC_URL=
