# Bắt buộc: tạo app tại https://dashboard.privy.io (bật login Email + Google,
# Embedded wallets: create on login)
NEXT_PUBLIC_PRIVY_APP_ID=

# "base" cho mainnet; bỏ trống / giá trị khác = Ethereum Sepolia (dev)
NEXT_PUBLIC_CHAIN=

# Backend engine (web/API.md). Đặt = FE dùng backend (portfolio/operations/on-ramp) — chạy
# thật e2e. Bỏ trống = client sim (standalone, không cần backend).
# Dev backend: cd backend && npx wrangler dev --port 8789  →  http://localhost:8789
NEXT_PUBLIC_API_URL=

# Địa chỉ AccountFactory khi contracts deploy (Vũ cung cấp).
# Bỏ trống = địa chỉ heo đất là chính ví embedded.
NEXT_PUBLIC_FACTORY_ADDRESS=
